  "Obsidian.Obsidian"
)

# ========================================
# Result Summary
# ========================================
Write-Host "`n========================================" -ForegroundColor Cyan
Write-Host " Installation Complete" -ForegroundColor Cyan
Write-Host "========================================" -ForegroundColor Cyan

if ($script:failedPackages.Count -gt 0) {
  Write-Host "`nThe following packages failed or were skipped:" -ForegroundColor Yellow
  $script:failedPackages | ForEach-Object { Write-Host "  - $_" -ForegroundColor DarkYellow }
  Write-Host "`n(Already installed packages may also appear here)" -ForegroundColor Gray
} else {
  Write-Host "`nAll packages installed successfully." -ForegroundColor Green
}

