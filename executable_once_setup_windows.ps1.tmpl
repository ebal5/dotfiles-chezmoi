{{ if eq .chezmoi.os "windows" }}
# Windows Setup Script with Error Handling
# =========================================

$ErrorActionPreference = "Continue"

# Check winget availability
if (-not (Get-Command winget -ErrorAction SilentlyContinue)) {
  Write-Host "Error: winget is not available. Aborting." -ForegroundColor Red
  exit 1
}

# Install function with error handling
$script:failedPackages = @()

function Install-WingetPackages {
  param(
    [string]$Category,
    [string[]]$Packages
  )

  Write-Host "`n========================================" -ForegroundColor Cyan
  Write-Host " $Category" -ForegroundColor Cyan
  Write-Host "========================================" -ForegroundColor Cyan

  foreach ($pkg in $Packages) {
    Write-Host "Installing: $pkg" -ForegroundColor Yellow
    winget install --id $pkg --accept-source-agreements --accept-package-agreements -e
    if ($LASTEXITCODE -ne 0) {
      Write-Host "  -> Failed or already installed: $pkg" -ForegroundColor DarkYellow
      $script:failedPackages += $pkg
    } else {
      Write-Host "  -> Success: $pkg" -ForegroundColor Green
    }
  }
}

# ========================================
# Package Installation
# ========================================

Install-WingetPackages "Basic Tools & Utilities" @(
  "7zip.7zip"
  "cURL.cURL"
  "Insecure.Nmap"
  "jqlang.jq"
