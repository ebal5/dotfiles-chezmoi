# Shim definitions for uvx/pnpm wrapper scripts
# Format: runner:package[:alias]
# - runner: uvx or pnpm
# - package: package name (may include @version)
# - alias (optional): command name override (required if package contains @version)
#
# Generated shims are placed in ~/.scripts/ with marker comment
# "AUTO-GENERATED by chezmoi shim" for auto-cleanup.

# Python tools (uvx)
uvx:ruff
uvx:bandit
uvx:mypy
uvx:ty

# JS/TS tools (pnpm dlx)
pnpm:markdownlint-cli2
pnpm:ccmanager
pnpm:ccusage
pnpm:@biomejs/biome:biome
pnpm:serve
pnpm:npm-check-updates:ncu
pnpm:degit
pnpm:difit
