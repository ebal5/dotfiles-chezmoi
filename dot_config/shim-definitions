# Shim definitions for uvx/bunx wrapper scripts
# Format: runner:package[:alias]
# - runner: uvx or bunx
# - package: package name (may include @version)
# - alias (optional): command name override (required if package contains @version)
#
# Generated shims are placed in ~/.scripts/ with marker comment
# "AUTO-GENERATED by chezmoi shim" for auto-cleanup.

# Python tools (uvx)
uvx:ruff
uvx:bandit
uvx:mypy
uvx:ty

# JS/TS tools (bunx)
bunx:markdownlint-cli2
bunx:ccmanager
bunx:ccusage
bunx:@biomejs/biome:biome
bunx:serve
bunx:npm-check-updates:ncu
bunx:degit
bunx:difit
