# Chezmoi ignore file
# このファイルは、chezmoiがホームディレクトリに適用しないファイルやディレクトリを指定します。
# 新しいドキュメントファイルや一時ファイルを作成した場合は、
# 必要に応じてこのファイルに追記してください。

# Documentation files - ドキュメントファイル
# ルート直下の .md のみ除外（dot_claude/ 配下の SKILL.md や
# rules/*.md はホームへ展開する必要があるため除外しない）
/*.md

# Superpowers docs - 設計ドキュメント
docs/

# Development and maintenance files - 開発・メンテナンス用ファイル
.gitignore
.github/
.pre-commit-config.yaml
.secrets.baseline

# Linter configuration files - リンター設定ファイル
.markdownlint-cli2.yaml
.markdownlint.yaml
.shellcheckrc

# Symlink source files - シンボリックリンクのソースファイル
.claude/settings.json.src
.claude/.mcp.json.src

# Backup files - バックアップファイル
bakups/
*.bak
*.backup
*~

# Temporary files - 一時ファイル
*.tmp
*.temp

# IDE and editor files - IDE・エディタファイル
.vscode/
.idea/
*.swp
*.swo

# Nix files - Nixファイル
flake.nix
flake.lock

# ========================================
# Platform-specific ignores - プラットフォーム別除外
# ========================================

{{ if eq .chezmoi.os "windows" }}
# Linux/Unix専用ファイル（Windowsでは除外）
.bashrc
.bash_profile
.zshrc
.zshenv
.profile
.scripts/
.config/sh-like-aliases
.config/tmux/
executable_once_setup_ubuntu.sh.tmpl
{{ end }}

{{ if ne .chezmoi.os "windows" }}
# Windows専用ファイル（Linux/macOSでは除外）
.config/powershell/
executable_once_setup_windows.ps1.tmpl
run_after_setup_powershell_profile.ps1.tmpl
{{ end }}
